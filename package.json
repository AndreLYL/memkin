{
  "name": "memkin",
  "version": "0.4.3",
  "description": "Local-first personal memory system — extracts signals from Feishu/Lark chats and AI-agent sessions into a private knowledge graph, served to any agent via MCP",
  "type": "module",
  "bin": {
    "memkin": "./bin/memkin.mjs"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "web/dist/",
    "bin/",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/AndreLYL/memkin#readme",
  "bugs": {
    "url": "https://github.com/AndreLYL/memkin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "setup": "bun install && cd web && bun install",
    "dev": "bun src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "gen:assets": "node scripts/gen-embedded-assets.mjs",
    "build": "node scripts/gen-embedded-assets.mjs && tsc && node scripts/post-build.mjs",
    "compile": "node scripts/gen-embedded-assets.mjs && bun build --compile src/cli.ts --outfile dist-bin/memkin",
    "typecheck": "tsc --noEmit",
    "prepack": "mv README.md README.zh-CN.md && cp README.en.md README.md",
    "postpack": "mv README.zh-CN.md README.md",
    "prepublishOnly": "npm run build",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "format": "biome format --write src/ tests/",
    "serve": "bun src/cli.ts serve",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:preview": "cd web && bun run preview"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^11.1.0",
    "fast-glob": "^3.3.3",
    "hono": "^4.12.23",
    "ink": "^7.0.5",
    "openai": "^6.39.0",
    "pg": "^8.22.0",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.7",
    "react-devtools-core": "^6.1.5",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.16",
    "typescript": "^6.0.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "mcp",
    "agent-memory",
    "local-first",
    "knowledge-graph",
    "feishu",
    "lark",
    "claude-code",
    "codex",
    "ai-agent",
    "self-hosted",
    "personal-knowledge-management",
    "signal-extraction",
    "conversation-mining",
    "pglite",
    "cli"
  ],
  "author": "AndreLYL (https://github.com/AndreLYL)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreLYL/memkin.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
