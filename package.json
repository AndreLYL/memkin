{
  "name": "memoark",
  "version": "0.2.0",
  "description": "Local-first personal memory extraction and storage",
  "type": "module",
  "bin": {
    "memoark": "./bin/memoark.mjs"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "tsc && node scripts/post-build.mjs",
    "prepublishOnly": "npm run build",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "format": "biome format --write src/ tests/",
    "serve": "bun src/cli.ts serve",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:preview": "cd web && bun run preview"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^11.1.0",
    "hono": "^4.12.23",
    "ink": "^7.0.5",
    "openai": "^6.39.0",
    "react": "^19.2.7",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "fast-glob": "^3.3.3",
    "typescript": "^6.0.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "knowledge-graph",
    "signal-extraction",
    "claude-code",
    "codex",
    "ai-agent",
    "conversation-mining",
    "cli"
  ],
  "author": "AndreLYL",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreLYL/memoark.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
